            "UNSURE_EXPLICIT"
          ],
          "IF_CONFLICT_DETECTED": "REGENERATE_OR_PRESENT_CONFLICT_WITH_BOUNDED_ASSERTIONS",
          "IF_UNSURE_EXTERNAL": "MAP_TO_EXPLICIT_PRUDENCE",
          "TAGS": [
            "SOURCE_VERIFIED_WEB",
            "SOURCE_PARTIAL_WEB",
            "SOURCE_CONFLICT_RESOLVED",
            "SOURCE_UNSURE_EXTERNAL"
          ]
        }
      },
      "SAFETY_LAWS": {
        "HNERONS_01": "Ne_jamais_confondre_verification_externe_et_verite_absolue",
        "HNERONS_02": "Ne_jamais_envoyer_de_donnees_privees_dans_les_requetes_externes",
        "HNERONS_03": "Bloquer_l_assertivite_forte_si_la_verification_est_insuffisante",
        "HNERONS_04": "Rendre_l_incertitude_visible_plutot_que_de_la_masquer",
        "HNERONS_05": "Prioriser_les_sources_primaires_ou_officielles_quand_elles_existent",
        "HNERONS_06": "Journaliser_les_raisons_de_qualification_pour_audit"
      },
      "THREAT_MODEL": {
        "RISKS": [
          "source_poisoning_or_low_authority_results",
          "stale_sources_on_dynamic_claims",
          "private_data_leakage_in_queries",
          "false_consensus_from_weak_sources",
          "latency_spike_under_high_claim_volume"
        ],
        "MITIGATIONS": [
          "authority_rank_and_source_filters",
          "freshness_requirement_by_claim_type",
          "query_redaction_and_no_private_data_outbound",
          "weighted_consensus_not_top_k_only",
          "safe_degrade_when_budget_or_lookup_fails"
        ]
      },
      "TELEMETRY": {
        "LOGGING": "MINIMAL_AUDITABLE",
        "FIELDS": [
          "timestamp",
          "request_id",
          "claim_count",
          "claim_types",
          "status_distribution",
          "selected_sources",
          "conflict_rate",
          "degrade_mode",
          "lookup_latency_ms"
        ],
        "RETENTION_DAYS": 7,
        "NO_PRIVATE_CONTENT_STORAGE": true
      },
      "TRIGGERS": {
        "AUTO": {
          "ON": "pre_emit_if_verifiable_claim_detected",
          "RUN_ONLY_IF": "factual_risk_or_freshness_signal_present",
          "BYPASS_IF": "no_verifiable_claims_and_low_risk"
        },
        "MANUAL": {
          "COMMANDS": [
            "H-NERONS:VERIFY",
            "H-NERONS:REPORT",
            "H-NERONS:SAFE_MODE"
          ]
        }
      }
    }
  }
}

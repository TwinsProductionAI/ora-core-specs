            "FRESHNESS",
            "RELEVANCE",
            "INTER_SOURCE_AGREEMENT"
          ],
          "MIN_AUTHORITY": "RECOGNIZED_SECONDARY"
        },
        "OUTBOUND_PRIVACY": {

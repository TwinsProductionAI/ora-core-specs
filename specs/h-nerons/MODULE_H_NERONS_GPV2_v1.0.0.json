          "IF_SIGNIFICANT_CONFLICT": "CONFLICT_DETECTED",
          "IF_EXTERNAL_DATA_INSUFFICIENT": "UNSURE_EXTERNAL",
          "IF_CRITICAL_AND_UNVERIFIED": "UNSURE_EXPLICIT"
        }
      },
      "QUALIFICATION_ENGINE": {
        "STATUSES": {
          "VERIFIED": {
            "ALLOW": true,
            "ACTION": "ALLOW_NORMAL_FORMULATION"
          },
          "PARTIALLY_VERIFIED": {
            "ALLOW": true,
            "ACTION": "ALLOW_WITH_SCOPE_LIMIT_AND_EXPLICIT_RESERVES"
          },
          "CONFLICT_DETECTED": {
            "ALLOW": true,
            "ACTION": "REGENERATE_CONSTRAINED_OR_PRESENT_CONFLICT"
          },
          "UNSURE_EXTERNAL": {
            "ALLOW": true,
            "ACTION": "DOWNGRADE_ASSERTIVENESS"
          },
          "UNSURE_EXPLICIT": {
            "ALLOW": true,
            "ACTION": "BLOCK_STRONG_CLAIM_AND_EXPOSE_UNCERTAINTY"
          }
        },
        "HARD_BLOCK_IF": [
          "critical_claim_and_status_not_verified",
          "strong_claim_without_sufficient_verification"
        ]
      },
      "REGENERATION_POLICY": {
        "ALLOW_NEW_FACTS": false,
        "MUST_KEEP_SCOPE_BOUNDARIES": true,
        "IF_VERIFIED": "ALLOW_NORMAL",
        "IF_PARTIALLY_VERIFIED": "LIMIT_SCOPE_AND_EXPOSE_GAPS",
        "IF_CONFLICT_DETECTED": "REGENERATE_UNDER_EXTERNAL_CONSTRAINTS_OR_EMIT_CONFLICT_NOTICE",
        "IF_UNSURE_EXTERNAL": "SAFE_DEGRADE_TO_PRUDENT_RESPONSE",
        "IF_UNSURE_EXPLICIT": "EMIT_CLEAR_UNCERTAINTY_AND_BLOCK_STRONG_ASSERTION"
      },
      "OUTPUTS": {

                                                                            "SUGGESTION_MARK":  "SUGGESTION"
                                                                        },
                                                                 "NATIVE_FINAL":  {
                                                                                      "ROLE":  "USER_NATIVE_OUTPUT",
                                                                                      "RULES":  [
                                                                                                    "Must be user facing only.",

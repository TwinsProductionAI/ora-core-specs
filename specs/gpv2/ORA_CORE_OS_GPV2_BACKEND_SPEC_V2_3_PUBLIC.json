                                                         "NEVER_SUPPRESS_NORMATIVE_LAYERS":  true
                                                     },
                                  "EXEC_RULES":  {
                                                     "R0":  "Never skip compile order on backend.",
                                                     "R1":  "JSON is container, GL is truth contract, GL_G is compressed index and route layer.",
                                                     "R2":  "If EN or FR conflict with GL, GL wins and derived renders must be regenerated.",
                                                     "R3":  "If user data is missing, emit GL.UNSURE and never invent as FACT.",
                                                     "R4":  "Suggestions must be marked SUGGESTION in EN FR and NATIVE_FINAL.",
                                                     "R5":  "GL primitives are deterministic with stable ordering and no spaces after commas.",
                                                     "R6":  "GL_G uses tokens only, no prose, ASCII-safe.",
                                                     "R7":  "IDX is required and cache key must include ID VERSION and HASH.",
                                                     "R8":  "HASH is mandatory for stable backend cache unless execution is explicitly ephemeral.",
                                                     "R9":  "External factual claim requires SOURCE or UNSURE plus risk downgrade.",
                                                     "R10":  "GL_G must preserve uncertainty and risk through STAT or TAG, never by prose.",
                                                     "R11":  "GLYPH_UI never gates execution."
                                                 }
                              },
                 "LOSS_POLICY":  {

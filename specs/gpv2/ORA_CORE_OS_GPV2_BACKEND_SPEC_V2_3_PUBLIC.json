                                                                            "PRIMITIVES":  [
                                                                                               "FACT()",
                                                                                               "ASSERT()",
                                                                                               "UNSURE()",
                                                                                               "UNIT()",
                                                                                               "DATE()",
                                                                                               "LIMIT()",
                                                                                               "SOURCE()",
                                                                                               "REF()",
                                                                                               "STATE()",
                                                                                               "RISK()",
                                                                                               "BLOCK()"
                                                                                           ],
                                                                            "RULES":  [
                                                                                          "If uncertain then UNSURE is required.",
                                                                                          "No embellishment.",
                                                                                          "All user constraints go to LIMIT or ASSERT.",
                                                                                          "Deterministic ordering: LIMIT ASSERT FACT SOURCE REF STATE RISK UNSURE GL_TRANS.",
                                                                                          "Every sensitive FACT should be linkable to SOURCE REF or explicit uncertainty."
                                                                                      ]
                                                                        },
                                                                 "GL_G":  {
                                                                              "ROLE":  "INDEX_COMPRESS_LAYER",
                                                                              "USE_FOR":  [
                                                                                              "tags",
                                                                                              "compression",
                                                                                              "routing",
                                                                                              "cache keys",
                                                                                              "hash",
                                                                                              "state carry"
                                                                                          ],
                                                                              "STYLE":  "short tokens ASCII-safe referential",
                                                                              "PRIMITIVES":  [
                                                                                                 "IDX()",
                                                                                                 "TAG()",
                                                                                                 "HASH()",
                                                                                                 "MAP()",
                                                                                                 "ROUTE()",
                                                                                                 "PACK()",
                                                                                                 "STAT()",
                                                                                                 "LINK()"
                                                                                             ],
                                                                              "RULES":  [
                                                                                            "No long sentences.",
                                                                                            "No prose.",
                                                                                            "IDX required.",
                                                                                            "HASH required for stable backend cache.",
                                                                                            "Tags stable across iterations for same concepts.",
                                                                                            "No user private content beyond approved IDs and non-sensitive tags.",
                                                                                            "Must preserve uncertainty risk and route criticality via STAT TAG or LINK."
                                                                                        ]
                                                                          },
                                                                 "EN":  {
                                                                            "ROLE":  "TECHNICAL_RENDER_LAYER",
